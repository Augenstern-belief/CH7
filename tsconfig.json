{
  "compilerOptions": {
    "target": "ES5",
    "module": "UMD",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": false,
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true
  },
  "include": [
    "./js/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
